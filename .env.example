APP_ENV=dev
LLM_PROVIDER=gemini
GOOGLE_API_KEY=your_google_api_key
GEMINI_MODEL_NAME=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL_NAME=gemini-embedding-001
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=docquest
POSTGRES_USER=docquest_user
POSTGRES_PASSWORD=strong_password_here
POSTGRES_SSLMODE=disable
# Optional override (if set, this takes priority over POSTGRES_* values):
# DATABASE_URL=postgresql+psycopg2://docquest_user:strong_password_here@localhost:5432/docquest
TOP_K=5
CHUNK_SIZE=800
CHUNK_OVERLAP=100
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
DATA_DIR=Data
STORAGE_DIR=storage
UPLOAD_DIR=uploads
AUTH_USERNAME=admin
AUTH_PASSWORD=change_this_password
AUTH_SECRET_KEY=replace_with_a_long_random_secret
AUTH_ALGORITHM=HS256
AUTH_TOKEN_EXPIRE_MINUTES=720
