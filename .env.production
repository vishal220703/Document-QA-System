# Production Environment Variables for Render + Neon + Vercel Deployment
# This is a template. Set actual values in your Render dashboard.

# Application Environment
APP_ENV=production
LLM_PROVIDER=gemini

# Gemini API Key (GET THIS FROM: https://aistudio.google.com/app/apikeys)
# DO NOT commit this to GitHub; set it only in Render dashboard
GOOGLE_API_KEY=your_google_api_key_here

# LLM Configuration
GEMINI_MODEL_NAME=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL_NAME=gemini-embedding-001

# Database Configuration - USE NEON URL
# Get this from Neon console (copy the full URL with psycopg2 driver)
# Format: postgresql+psycopg2://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql+psycopg2://neon_user:neon_password@host.neon.tech/neon_db?sslmode=require

# Retrieval Configuration
TOP_K=5
CHUNK_SIZE=800
CHUNK_OVERLAP=100

# CORS Origins - ADD YOUR VERCEL FRONTEND URL
# Format: https://your-project.vercel.app
# Keep localhost entries for local testing (optional)
CORS_ORIGINS=https://your-project.vercel.app,http://localhost:3000,http://127.0.0.1:3000

# Storage Directories (Render free tier: non-persistent, will reset after deploy)
# For production: consider moving to Cloud Storage (AWS S3, GCS, etc.)
DATA_DIR=/tmp/data
STORAGE_DIR=/tmp/storage
UPLOAD_DIR=/tmp/uploads

# Authentication
AUTH_USERNAME=admin
AUTH_PASSWORD=change_this_to_a_strong_password
# Generate this: python -c "import secrets; print(secrets.token_urlsafe(32))"
AUTH_SECRET_KEY=generate_a_long_random_secret_key_here
AUTH_ALGORITHM=HS256
AUTH_TOKEN_EXPIRE_MINUTES=720

# SSL Mode for PostgreSQL (Neon requires SSL)
POSTGRES_SSLMODE=require
